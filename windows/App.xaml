<Application
    x:Class="SeaDropWindows.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    RequestedTheme="Light">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>
            <FontFamily x:Key="YoungSerif">ms-appx:///Assets/Fonts/YoungSerif-Regular.ttf#Young Serif</FontFamily>
            <FontFamily x:Key="Inter">ms-appx:///Assets/Fonts/Inter-Regular.ttf#Inter</FontFamily>
            <Color x:Key="SpaceOrange">#E85D00</Color>
            <Color x:Key="BackgroundWhite">#FEFEFE</Color>
            <SolidColorBrush x:Key="SpaceOrangeBrush" Color="{StaticResource SpaceOrange}" />
            <SolidColorBrush x:Key="BackgroundWhiteBrush" Color="{StaticResource BackgroundWhite}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>