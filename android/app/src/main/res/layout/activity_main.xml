<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/seadrop_bg"
    android:clipToPadding="false"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:maxWidth="480dp"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_seadrop_logo"
                android:contentDescription="@string/app_name" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    style="@style/TextAppearance.SeaDrop.TitleLarge" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seamless Drop"
                    style="@style/TextAppearance.SeaDrop.BodySmall"
                    android:textColor="@color/seadrop_text_muted"
                    android:layout_marginTop="-2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Status Pill -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/status_pill_background"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/vStatusIndicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/status_indicator"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Initializing..."
                style="@style/TextAppearance.SeaDrop.BodySmall"
                android:textColor="@color/seadrop_on_primary" />
        </LinearLayout>

        <!-- Device Name Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SeaDrop.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Device Name"
                    style="@style/TextAppearance.SeaDrop.TitleMedium" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilDeviceName"
                    style="@style/Widget.SeaDrop.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Enter a name">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDeviceName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLength="32" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveName"
                    style="@style/Widget.SeaDrop.Button.Primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Save" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Device SSID Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SeaDrop.Card"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Device"
                    style="@style/TextAppearance.SeaDrop.TitleMedium" />

                <TextView
                    android:id="@+id/tvSeaDropSsid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Not registered"
                    style="@style/TextAppearance.SeaDrop.BodyMedium" />

                <TextView
                    android:id="@+id/tvDeviceInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text=""
                    android:visibility="gone"
                    style="@style/TextAppearance.SeaDrop.BodySmall"
                    android:textColor="@color/seadrop_green" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Registration Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SeaDrop.Card"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Registration"
                    style="@style/TextAppearance.SeaDrop.TitleMedium" />

                <TextView
                    android:id="@+id/tvRegistrationStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Power on SeaDrop to register"
                    style="@style/TextAppearance.SeaDrop.BodyMedium"
                    android:lineSpacingExtra="3dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp"
                    android:gravity="end">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReRegister"
                        style="@style/Widget.SeaDrop.Button.Secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Re-register"
                        android:visibility="gone" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRegister"
                        style="@style/Widget.SeaDrop.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Register" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Footer Info -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:text="SeaDrop transfers files over WiFi — no internet required."
            style="@style/TextAppearance.SeaDrop.BodySmall"
            android:textColor="@color/seadrop_text_muted" />
    </LinearLayout>
</ScrollView>