<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/seadrop_bg"
    android:clipToPadding="false"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:maxWidth="560dp"
        android:orientation="vertical"
        android:spacing="16dp">

        <!-- Hero Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/hero_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/seadrop_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:spacing="12dp">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_seadrop_logo"
                    android:contentDescription="@string/app_name" />

                <TextView
                    style="@style/TextAppearance.SeaDrop.HeadlineMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SeaDrop Setup" />

                <TextView
                    style="@style/TextAppearance.SeaDrop.BodyLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#F1F5F9"
                    android:text="One-time setup for seamless transfers" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/status_pill_background"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:layout_marginTop="4dp">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/status_indicator"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        style="@style/TextAppearance.SeaDrop.BodySmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Registration Mode"
                        android:textColor="@color/seadrop_on_primary" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Device Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SeaDrop.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:spacing="12dp">

                <TextView
                    style="@style/TextAppearance.SeaDrop.TitleMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SeaDrop Device" />

                <TextView
                    style="@style/TextAppearance.SeaDrop.BodyMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Power on SeaDrop and hold BOOT for 3 seconds until REGISTRATION MODE appears on screen."
                    android:lineSpacingExtra="4dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilSsid"
                    style="@style/Widget.SeaDrop.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="SeaDrop SSID (shown on device screen)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSsid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLength="32" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Your Name Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SeaDrop.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:spacing="12dp">

                <TextView
                    style="@style/TextAppearance.SeaDrop.TitleMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Device Name" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilDeviceName"
                    style="@style/Widget.SeaDrop.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter a name for this device">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDeviceName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLength="32" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Status -->
        <TextView
            style="@style/TextAppearance.SeaDrop.BodyMedium"
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

        <!-- Register Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegister"
            style="@style/Widget.SeaDrop.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Register" />

        <!-- Permissions Note -->
        <TextView
            style="@style/TextAppearance.SeaDrop.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="Requires WiFi and location permissions for discovery." />
    </LinearLayout>
</ScrollView>